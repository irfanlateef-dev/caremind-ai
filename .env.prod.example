# Production — docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# Host nginx: deploy/nginx-caremind.example.conf → caremind-ai.duckdns.org
# Compose joins external network divescale-net (start main divescale stack first)

# ─── Public URLs (must match nginx server_name + cert) ───────────────────────
FRONTEND_URL=https://caremind-ai.duckdns.org
APP_URL=https://caremind-ai.duckdns.org

# Frontend build — empty = browser calls same-origin /api (host nginx proxies to caremind-backend)
VITE_API_BASE_URL=
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Object storage (shared global MinIO — API host, not console) ────────────
S3_ENDPOINT=https://divescale-s3.duckdns.org
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Databases ───────────────────────────────────────────────────────────────
CENTRAL_DB_USER=postgres
CENTRAL_DB_PASSWORD=change-me-strong
CENTRAL_DB_NAME=caremind_central

TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=change-me-strong
TENANT_DB_NAME_PREFIX=caremind_tenant_

REDIS_URL=redis://redis:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-long-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-another-32-char-secret
REFRESH_TOKEN_EXPIRES_IN=5d

# ─── AI — OpenRouter (MVP) ───────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── Embeddings — Voyage AI (MVP) ────────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ─── STT — Deepgram (MVP) ───────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ─── LiveKit (hosted) ────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@your-domain.com
RESEND_API_KEY=

# ─── Demo seed (optional) ──────────────────────────────────────────────────────
# SEED_DEMO_PASSWORD=Demo123!
