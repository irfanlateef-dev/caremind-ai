generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/central-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CENTRAL_DATABASE_URL")
}

enum UserRole {
  patient
  doctor
  admin
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  dbUrl     String   // encrypted at rest via application-layer encryption
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  users User[]

  @@map("organizations")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  role          UserRole
  orgId         String
  mfaEnabled    Boolean      @default(false)
  mfaSecret     String?      // TOTP secret (encrypted)
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  lastLoginAt   DateTime?

  organization        Organization         @relation(fields: [orgId], references: [id])
  refreshTokens       RefreshToken[]
  trustedDevices      TrustedDevice[]
  passwordResetTokens PasswordResetToken[]

  @@index([orgId])
  @@map("users")
}

model TrustedDevice {
  id           String   @id @default(uuid())
  userId       String
  deviceHash   String
  deviceName   String
  trustedUntil DateTime
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@map("trusted_devices")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}
