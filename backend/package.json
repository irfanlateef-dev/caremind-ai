{
  "name": "caremind-ai-backend",
  "version": "1.0.0",
  "description": "CareMind AI Backend — TypeScript/Node.js",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:central:migrate": "bash scripts/prisma-central-migrate.sh",
    "prisma:central:generate": "prisma generate --schema=prisma/central/schema.prisma",
    "prisma:tenant:generate": "prisma generate --schema=prisma/tenant/schema.prisma",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@deepgram/sdk": "^3.5.0",
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "openai": "^4.100.0",
    "otplib": "^12.0.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.3.1",
    "pino-http": "^10.2.0",
    "prisma": "^5.16.0",
    "puppeteer-core": "^22.12.1",
    "resend": "^3.4.0",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
