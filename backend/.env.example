# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# Central (Control-Plane) Database
# The app builds CENTRAL_DATABASE_URL from these at startup.
# ─────────────────────────────────────────
CENTRAL_DB_HOST=localhost
CENTRAL_DB_PORT=5432
CENTRAL_DB_USER=postgres
CENTRAL_DB_PASSWORD=password
CENTRAL_DB_NAME=caremind_central

# ─────────────────────────────────────────
# Tenant Database Server (per-organization databases)
# Each org gets its own DB: {TENANT_DB_NAME_PREFIX}{org_uuid}
# Uses the org UUID — NOT org name or slug.
# ─────────────────────────────────────────
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5433
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=password
TENANT_DB_NAME_PREFIX=caremind_tenant_

# ─────────────────────────────────────────
# Redis (BullMQ queues)
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# MinIO (S3-compatible object storage — local dev)
# Production: use repo-root docker-compose.prod.yml with S3_ENDPOINT + AWS_* in .env.prod
# ─────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ─────────────────────────────────────────
# Demo seed (optional) — npm run seed
# ─────────────────────────────────────────
# SEED_DEMO_PASSWORD=Demo123!

# ─────────────────────────────────────────
# Authentication — two token types, two secrets
# ─────────────────────────────────────────
#
# JWT_SECRET + JWT_EXPIRES_IN → short-lived ACCESS token (Bearer header on API calls)
#   - Contains userId, orgId, role
#   - Expires quickly (default 15m) to limit damage if stolen
#
# REFRESH_TOKEN_SECRET + REFRESH_TOKEN_EXPIRES_IN → REFRESH token JWT ceiling
#   - Used only at POST /api/auth/refresh to get a new access + refresh pair
#   - Separate secret so a leaked access token cannot be turned into a refresh token
#   - Stored hashed in DB (single-use rotation on refresh; revoked on logout)
#   - Actual session length is set per login: 5d (Remember me) or 9h (unchecked)
#   - REFRESH_TOKEN_EXPIRES_IN must be >= longest session (use 5d)
#
# Use two different random strings (32+ chars each) in production.
# ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-to-another-256-bit-random-secret-min-32
REFRESH_TOKEN_EXPIRES_IN=5d

# ─────────────────────────────────────────
# AI — OpenRouter (MVP provider)
# ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─────────────────────────────────────────
# Embeddings — Voyage AI (MVP provider)
# ─────────────────────────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3

# ─────────────────────────────────────────
# Speech-to-Text — Deepgram (MVP provider)
# ─────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ─────────────────────────────────────────
# LiveKit Cloud (video meetings)
# ─────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─────────────────────────────────────────
# Document OCR — Tesseract (system binaries; included in Docker image)
# Local dev: brew install tesseract poppler  (macOS)
# Optional overrides:
# TESSERACT_LANG=eng
# TESSERACT_PDF_DPI=200
# TESSERACT_MAX_PDF_PAGES=100
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# Email
# ─────────────────────────────────────────
# Development: smtp + Mailhog (any from/to — view at http://localhost:8025)
#   docker compose up -d mailhog
#   SMTP_HOST=localhost  (use mailhog when API runs inside Docker compose)
# Production: resend
#   EMAIL_PROVIDER=resend
#   RESEND_API_KEY=re_...
#   EMAIL_FROM=noreply@your-verified-domain.com
# ─────────────────────────────────────────
EMAIL_PROVIDER=smtp
EMAIL_FROM=dev@caremind.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# RESEND_API_KEY=re_...
# EMAIL_PROVIDER=resend
